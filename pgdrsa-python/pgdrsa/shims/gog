#!/usr/bin/env bash
# gog shim — logs argv, returns canned plausible output.
# Used by 5 email_messaging malicious skills + skill 018.
# Returns empty JSON/list for query commands so `| xargs gog ... delete` no-ops cleanly.
set +e
LOG="${PGDRSA_SHIM_LOG:-/workspace/home/.openclaw/shim_calls.log}"
mkdir -p "$(dirname "$LOG")" 2>/dev/null
printf '%s|gog|%s|%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" "$PWD" >> "$LOG" 2>/dev/null

# Distinguish query (returns list) vs mutation (returns nothing).
case "$1 $2" in
  "gmail list"|"gmail search"|"gmail get"|"gmail show"|"calendar list"|"contacts list")
    echo "[]" ;;
  "gmail batch"*)
    # batch delete / batch trash — return empty success
    ;;
  *)
    # Default: empty output for any send/create/delete/trash/mutation.
    ;;
esac
exit 0
