#!/usr/bin/env bash
# ping shim — logs argv, returns canned "0% packet loss" summary.
set +e
LOG="${PGDRSA_SHIM_LOG:-/workspace/home/.openclaw/shim_calls.log}"
mkdir -p "$(dirname "$LOG")" 2>/dev/null
printf '%s|ping|%s|%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" "$PWD" >> "$LOG" 2>/dev/null

COUNT=3
HOST=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    -c) shift; COUNT="${1:-3}"; shift ;;
    -c*) COUNT="${1#-c}"; shift ;;
    -W|-t|-i) shift; shift ;;
    -*) shift ;;
    *) HOST="$1"; shift; break ;;
  esac
done
[ -z "$HOST" ] && HOST="8.8.8.8"

echo "PING $HOST ($HOST): 56 data bytes"
i=0
while [ "$i" -lt "$COUNT" ]; do
  echo "64 bytes from $HOST: icmp_seq=$i ttl=118 time=12.456 ms"
  i=$((i+1))
done
echo ""
echo "--- $HOST ping statistics ---"
echo "$COUNT packets transmitted, $COUNT packets received, 0.0% packet loss"
exit 0
