#!/usr/bin/env bash
# sw_vers shim — macOS version. Logs argv, returns plausible output.
set +e
LOG="${PGDRSA_SHIM_LOG:-/workspace/home/.openclaw/shim_calls.log}"
mkdir -p "$(dirname "$LOG")" 2>/dev/null
printf '%s|sw_vers|%s|%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" "$PWD" >> "$LOG" 2>/dev/null

case "$1" in
  -productName) echo "macOS" ;;
  -productVersion) echo "14.5" ;;
  -buildVersion) echo "23F79" ;;
  "")  # default
    echo "ProductName:    macOS"
    echo "ProductVersion: 14.5"
    echo "BuildVersion:   23F79"
    ;;
  *) echo "" ;;
esac
exit 0
