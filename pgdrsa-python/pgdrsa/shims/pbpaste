#!/usr/bin/env bash
# pbpaste shim — clipboard is empty in the sandbox. Logs argv, returns nothing.
set +e
LOG="${PGDRSA_SHIM_LOG:-/workspace/home/.openclaw/shim_calls.log}"
mkdir -p "$(dirname "$LOG")" 2>/dev/null
printf '%s|pbpaste|%s|%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" "$PWD" >> "$LOG" 2>/dev/null
exit 0
